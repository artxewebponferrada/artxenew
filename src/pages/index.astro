---
// Import the necessary components
import MainLayout from "@/layouts/MainLayout.astro";
import HeroSection from "@components/sections/landing/HeroSection.astro";
import HeroSectionAlt from "@components/sections/landing/HeroSectionAlt.astro";
import ClientsSection from "@components/sections/landing/ClientsSection.astro";
import FeaturesGeneral from "@components/sections/features/FeaturesGeneral.astro";
import FeaturesNavs from "@components/sections/features/FeaturesNavs.astro";
import TestimonialsSection from "@components/sections/testimonials/TestimonialsSection.astro";
import PricingSection from "@components/sections/pricing/PricingSection.astro";
import FAQ from "@components/sections/misc/FAQ.astro";
import AnnouncementBanner from "@components/ui/banners/AnnouncementBanner.astro";

import heroImage from "@images/hero-image.avif";
import faqs from "@data/faqs.json";
import features from "@data/features.json";
import pricing from "@data/pricing.json";
import featureImage from "@images/features-image.avif";
import construction from "@images/construction-image.avif";
import tools from "@images/automated-tools.avif";
import dashboard from "@images/dashboard-image.avif";
import { partnersData } from "@/data_files/constants";

const avatarSrcs: Array<string> = [
  "https://images.unsplash.com/photo-1568602471122-7832951cc4c5?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80",
  "https://images.unsplash.com/photo-1531927557220-a9e23c1e4794?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80",
  "https://images.unsplash.com/photo-1541101767792-f9b2b1c4f127?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&&auto=format&fit=facearea&facepad=3&w=300&h=300&q=80",
  "https://images.unsplash.com/photo-1492562080023-ab3db95bfbce?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80",
];
---

<MainLayout>
  <AnnouncementBanner
    btnId="dismiss-button"
    btnTitle="Pedir Presupuesto"
    url="/contacto"
  />

  <HeroSection
    title={`Tu web con <span class="text-yellow-500 dark:text-yellow-400">Artxe Web</span>`}
    subTitle="Diseño web y SEO al mejor precio. Páginas rápidas, seguras y optimizadas para posicionar en Google desde el primer día."
    primaryBtn="Pedir Presupuesto"
    primaryBtnURL="/contacto"
    secondaryBtn="Ver Proyectos"
    secondaryBtnURL="/proyectos"
    withReview={true}
    avatars={avatarSrcs}
    rating={`<span class="font-bold">4.8</span> / 5`}
    starCount={4}
    reviews={`+10 años de experiencia`}
    src={heroImage}
    alt="Diseño web y SEO de Artxe Web"
  />

  <ClientsSection
    title="Confían en Artxe Web"
    subTitle="Empresas y profesionales que ya mejoran su visibilidad online."
    partners={partnersData}
  />

  <FeaturesGeneral
    title="Diseño Web y SEO que impulsa tu negocio"
    subTitle="Creamos sitios rápidos, seguros y fáciles de gestionar. Combinamos diseño atractivo con estrategias SEO efectivas para atraer tráfico cualificado y convertir."
    src={featureImage}
    alt="Servicios de Artxe Web"
    features={features}
  />

  <FeaturesNavs
    title={`Servicios de <span class="text-yellow-500 dark:text-yellow-400">Artxe Web</span> para hacer crecer tu presencia online`}
    tabs={[
      {
        heading: "Diseño Web"
        ,
        content:
          "Webs atractivas, funcionales y responsive. Arquitectura clara, rendimiento alto y buenas prácticas de accesibilidad. Te enseñamos a gestionarla tú mismo.",
        svg: "house",
        src: construction,
        alt: "Estructura visual de un sitio web moderno",
        first: true,
      },
      {
        heading: "SEO y Analítica",
        content:
          "Investigación de palabras clave, SEO técnico, contenido optimizado y medición con analítica. Más visibilidad, más clientes, sin humo.",
        svg: "dashboard",
        src: dashboard,
        alt: "Panel con métricas de SEO y tráfico",
        second: true,
      },
      {
        heading: "Tienda Online & Marca",
        content:
          "Montamos tu e-commerce en WooCommerce y te ayudamos con identidad visual, logotipos y recursos creativos. Sencillo, seguro y listo para vender.",
        svg: "tools",
        src: tools,
        alt: "Herramientas digitales para comercio online",
      },
    ]}
  />

  <TestimonialsSection
    title="Lo que dicen nuestros clientes"
    subTitle="Resultados reales: más velocidad, mejor posicionamiento y soporte cercano."
    testimonials={[
      {
        content:
          "Artxe Web entendió lo que necesitábamos desde el primer día. La web carga muy rápido y el SEO nos ha traído clientes nuevos. 100% recomendables.",
        author: "Nombre Cliente 1",
        role: "Empresa Cliente 1",
        avatarSrc:
          "https://images.unsplash.com/photo-1593104547489-5cfb3839a3b5?q=80&w=1453&auto=format&fit=crop&ixlib=rb-4.0.3",
      },
    ]}
    statistics={[
      {
        count: "10+",
        description: "años de experiencia en diseño web y SEO",
      },
      {
        count: "200%",
        description: "de mejora media en visibilidad orgánica",
      },
      {
        count: "3s",
        description: "tiempos de carga objetivo por página",
      },
      {
        count: "98%",
        description: "satisfacción en soporte y mantenimiento",
      },
    ]}
  />

  <PricingSection pricing={pricing} />

  <FAQ title="Preguntas<br />Frecuentes" faqs={faqs} />

  <HeroSectionAlt
    title="¿Empezamos?"
    subTitle="Artxe Web: especialistas en diseño web y SEO. Webs 100% optimizadas, listas para crecer."
    url="/contacto"
  />
</MainLayout>
